# Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# ====================
# API Configuration
# ====================
# Base URL untuk backend API
NEXT_PUBLIC_API_BASE_URL=https://api.wajira.com/v1

# API Key (jika diperlukan)
NEXT_PUBLIC_API_KEY=your-api-key-here

# ====================
# Authentication
# ====================
# Auth domain (jika pakai third-party auth service)
NEXT_PUBLIC_AUTH_DOMAIN=auth.wajira.com

# JWT Secret (untuk server-side, jangan exposed ke client)
JWT_SECRET=your-super-secret-jwt-key-here-minimum-32-characters

# ====================
# Feature Flags
# ====================
# Enable/disable analytics
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# Enable/disable debug mode
NEXT_PUBLIC_DEBUG_MODE=false

# ====================
# External Services
# ====================
# Google Analytics ID (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Sentry DSN (optional - untuk error tracking)
NEXT_PUBLIC_SENTRY_DSN=

# ====================
# Development Only
# ====================
# Port untuk development server (default: 3000)
PORT=3000

# ====================
# Notes
# ====================
# - NEXT_PUBLIC_* variables akan exposed ke browser
# - Variables tanpa NEXT_PUBLIC_ hanya tersedia di server-side
# - Jangan commit .env.local ke repository!
# - Untuk production, set variables di Vercel/hosting platform
